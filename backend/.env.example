# ---- Pathway (the billing service that generates the invoice PDFs) ----
# Secret key you create in the Pathway dashboard ("Datenabruf über API" → ➕).
PATHWAY_API_KEY=
# Your Pathway shop id (from your screenshots this is the myshopify domain).
PATHWAY_SHOP_ID=bfe811.myshopify.com
# Usually leave as-is.
PATHWAY_BASE_URL=https://billing.platform.pathway-solutions.de
# On-demand customer portal (tier-2 fallback button). Leave as-is.
PATHWAY_PORTAL_BASE=https://app.billing.pathway-solutions.de

# ---- Shopify session-token verification ----
# From your Shopify app (the one created via `shopify app init`):
# Partners dashboard → your app → "Client ID" / "Client secret".
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=

# ---- Shopify Admin API (OPTIONAL — "airtight" mode only) ----
# Leave SHOPIFY_ADMIN_TOKEN empty to run in "session-only" mode (recommended to
# start): the backend still requires a valid logged-in customer, it just skips
# the extra per-order ownership lookup. Set it later to upgrade to airtight,
# where the backend confirms the order belongs to that exact customer.
# In 2026 this token comes from a one-time OAuth install (not "reveal once").
SHOPIFY_STORE_DOMAIN=bfe811.myshopify.com
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_ADMIN_API_VERSION=2025-07

# ---- Preview/demo only ----
# When set, /invoices serves THIS order's documents no matter which order is
# viewed — lets you preview the real card + working download on a store whose
# orders aren't in Pathway (e.g. the dev store). MUST be empty in production.
DEMO_INVOICE_ORDER_ID=

# ---- Local dev only ----
# Set to "true" to skip all auth/ownership checks while testing locally.
# NEVER set this in production.
DISABLE_AUTH=false

PORT=8080
